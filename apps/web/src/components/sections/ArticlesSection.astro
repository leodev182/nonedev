---
import type { Locale } from '@/i18n'
import type { Article } from '@portfolio/contracts'
import { useTranslations, getLocalePath } from '@/i18n'

interface Props {
  locale: Locale
  articles: Article[]
}

const { locale, articles } = Astro.props
const t = useTranslations(locale)

function formatDate(iso: string, loc: Locale) {
  return new Intl.DateTimeFormat(loc === 'es' ? 'es-ES' : 'en-US', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
  }).format(new Date(iso))
}
---

<div class="section-divider"><hr /></div>

<section id="articulos" class="section">
  <div class="section__header">
    <p class="section__tag">{t('articulos', 'etiqueta')}</p>
    <h2 class="section__title">{t('articulos', 'titulo')}</h2>
    <p class="section__subtitle">{t('articulos', 'subtitulo')}</p>
  </div>

  <ul class="articles-list">
    {articles.map((article) => (
      <li>
        <a
          href={getLocalePath(locale, `/articulos/${article.slug}`)}
          class="article-row"
        >
          <div class="article-row__left">
            <span class="article-row__date">
              {article.publishedAt ? formatDate(article.publishedAt, locale) : ''}
            </span>
            {article.tags[0] && (
              <span class="article-row__tag">{article.tags[0]}</span>
            )}
          </div>
          <p class="article-row__title">{article.title}</p>
          <span class="article-row__arrow" aria-hidden="true">→</span>
        </a>
      </li>
    ))}
  </ul>

  <a href={getLocalePath(locale, '/articulos')} class="see-all">
    {t('articulos', 'verTodos')}
    <span class="see-all__arrow">→</span>
  </a>
</section>

<style>
  .articles-list {
    list-style: none;
    border-top: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .article-row {
    display: grid;
    grid-template-columns: 180px 1fr auto;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    margin: 0 -0.75rem;
    transition: background 0.2s var(--ease);
  }

  .article-row:hover { background: rgba(255, 255, 255, 0.025); }

  .article-row__left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
  }

  .article-row__date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-muted);
  }

  .article-row__tag {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-purple);
    background: var(--color-purple-dim);
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
  }

  .article-row__title {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-text);
  }

  .article-row__arrow {
    color: var(--color-muted);
    font-size: var(--text-sm);
    display: inline-block;
    transition: transform 0.2s var(--ease), color 0.2s var(--ease);
  }

  .article-row:hover .article-row__arrow {
    transform: translateX(4px);
    color: var(--color-text-secondary);
  }

  @media (max-width: 600px) {
    .article-row { grid-template-columns: 1fr auto; gap: 1rem; }
    .article-row__left { display: none; }
  }
</style>
