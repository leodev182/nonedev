{
  "framework": null,

  "buildCommand": "pnpm exec esbuild src/entry-vercel.ts --bundle --platform=node --target=node20 --format=cjs --outfile=api/index.js",

  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ],

  "functions": {
    "api/index.js": {
      "maxDuration": 10
    }
  }
}
