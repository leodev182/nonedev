---
import type { Locale } from '@/i18n'

interface Props { locale: Locale }
const { locale } = Astro.props

const copy = {
  es: {
    tag: 'CONTACTO',
    title: 'Hablemos',
    sub: 'Disponible para proyectos freelance, colaboraciones y oportunidades laborales.',
    email: 'Escríbeme un email',
    linkedin: 'Conéctate en LinkedIn',
    github: 'Ve mi código en GitHub',
  },
  en: {
    tag: 'CONTACT',
    title: "Let's talk",
    sub: 'Available for freelance projects, collaborations and job opportunities.',
    email: 'Send me an email',
    linkedin: 'Connect on LinkedIn',
    github: 'See my code on GitHub',
  },
}[locale]
---

<div class="section-divider"><hr /></div>

<section id="contacto" class="contact">
  <div class="contact__inner">
    <p class="contact__tag">{copy.tag}</p>
    <h2 class="contact__title">{copy.title}</h2>
    <p class="contact__sub">{copy.sub}</p>

    <div class="contact__links">
      <a href="mailto:leoartdev@gmail.com" class="contact-card contact-card--primary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        <div>
          <span class="contact-card__label">{copy.email}</span>
          <span class="contact-card__value">leoartdev@gmail.com</span>
        </div>
        <span class="contact-card__arrow">→</span>
      </a>

      <a href="https://www.linkedin.com/in/leoartdev" target="_blank" rel="noopener" class="contact-card">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        <div>
          <span class="contact-card__label">{copy.linkedin}</span>
          <span class="contact-card__value">linkedin.com/in/leoartdev</span>
        </div>
        <span class="contact-card__arrow">→</span>
      </a>

      <a href="https://github.com/leodev182" target="_blank" rel="noopener" class="contact-card">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        <div>
          <span class="contact-card__label">{copy.github}</span>
          <span class="contact-card__value">github.com/leodev182</span>
        </div>
        <span class="contact-card__arrow">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .contact { padding: 5rem 0 6rem; }

  .contact__inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .contact__tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: .18em;
    color: var(--color-green);
    margin-bottom: 1rem;
  }

  .contact__title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -.03em;
    margin-bottom: .75rem;
  }

  .contact__sub {
    font-size: var(--text-base);
    color: var(--color-muted);
    margin-bottom: 2.5rem;
    max-width: 500px;
  }

  .contact__links {
    display: flex;
    flex-direction: column;
    gap: .75rem;
    max-width: 560px;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: border-color .2s var(--ease), transform .2s var(--ease), box-shadow .2s var(--ease);
    color: var(--color-text-secondary);
  }

  .contact-card svg { flex-shrink: 0; color: var(--color-muted); transition: color .2s; }

  .contact-card > div { flex: 1; display: flex; flex-direction: column; gap: .15rem; }

  .contact-card__label { font-size: var(--text-sm); font-weight: 500; color: var(--color-text); }
  .contact-card__value { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-muted); }

  .contact-card__arrow { font-size: var(--text-sm); color: var(--color-muted); transition: transform .2s var(--ease), color .2s; }

  .contact-card:hover {
    border-color: rgba(139, 92, 246, 0.3);
    transform: translateX(4px);
    box-shadow: 0 4px 20px rgba(0,0,0,.25);
  }

  .contact-card:hover svg { color: var(--color-purple); }
  .contact-card:hover .contact-card__arrow { transform: translateX(3px); color: var(--color-purple); }

  .contact-card--primary:hover {
    border-color: rgba(0, 232, 122, 0.3);
  }
  .contact-card--primary:hover svg { color: var(--color-green); }
  .contact-card--primary:hover .contact-card__arrow { color: var(--color-green); }

  @media (max-width: 640px) {
    .contact__inner { padding: 0 1.25rem; }
  }
</style>
