{
  "framework": null,
  "outputDirectory": ".",
  "functions": {
    "api/index.ts": {
      "includeFiles": "node_modules/@portfolio/contracts/dist/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "ignoreCommand": "! git diff --quiet HEAD^ HEAD -- apps/api packages"
}
