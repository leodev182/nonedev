{
  "framework": null,

  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm exec esbuild src/entry-vercel.ts --bundle --platform=node --target=node20 --format=cjs --outfile=index.js",

  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ],

  "functions": {
    "index.js": {
      "maxDuration": 10
    }
  },
  "ignoreCommand": "! git diff --quiet HEAD~1 HEAD -- apps/api packages"
}
