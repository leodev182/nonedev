---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/components/shared/Navbar.astro'
import { getLocalePath } from '@/i18n'
import { getArticles } from '@/lib/api'

const locale = 'en'
const articles = await getArticles({ locale: 'en', pageSize: 20 })
---

<BaseLayout locale={locale} title="Articles — nonedev" description="I write about what I learn while building software.">
  <Navbar locale={locale} />
  <main class="articles-page">
    <div class="inner">
      <a href={getLocalePath(locale, '/')} class="back-link">← Back</a>
      <p class="tag">ARTICLES</p>
      <h1 class="title">What I write</h1>
      <p class="sub">Thoughts on software development, tools, and what I pick up along the way.</p>

      <ul class="list">
        {articles.map(article => (
          <li>
            <a href={getLocalePath(locale, `/articulos/${article.slug}`)} class="article-row">
              <div class="article-row__meta">
                <time datetime={article.publishedAt!}>
                  {new Date(article.publishedAt!).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' })}
                </time>
                <div class="article-row__tags">
                  {article.tags.slice(0, 3).map(tag => <span class="pill">{tag}</span>)}
                </div>
              </div>
              <h2 class="article-row__title">{article.title}</h2>
              <p class="article-row__summary">{article.summary}</p>
              <div class="article-row__footer">
                <span class="read-time">{article.readingTimeMin} min read</span>
                <span class="read-link">Read →</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </main>
</BaseLayout>

<style>
  .articles-page { min-height: 100svh; padding-top: var(--nav-h); }
  .inner { max-width: 720px; margin: 0 auto; padding: 4rem 2rem 6rem; }
  .back-link { display: inline-flex; align-items: center; gap: .4rem; font-size: var(--text-sm); color: var(--color-muted); margin-bottom: 2.5rem; transition: color .2s; }
  .back-link:hover { color: var(--color-text); }
  .tag { font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: .18em; color: var(--color-green); margin-bottom: 1rem; }
  .title { font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; letter-spacing: -.03em; margin-bottom: .75rem; }
  .sub { font-size: var(--text-base); color: var(--color-muted); margin-bottom: 3rem; }
  .list { list-style: none; display: flex; flex-direction: column; gap: 1px; }
  .article-row { display: block; padding: 1.75rem 0; border-bottom: 1px solid var(--color-border); transition: all .2s var(--ease); }
  .article-row:first-of-type { border-top: 1px solid var(--color-border); }
  .article-row__meta { display: flex; align-items: center; gap: 1rem; margin-bottom: .75rem; }
  time { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-muted); }
  .article-row__tags { display: flex; gap: .35rem; }
  .pill { font-family: var(--font-mono); font-size: 10px; color: var(--color-muted); background: rgba(255,255,255,.04); border: 1px solid var(--color-border); padding: .15rem .5rem; border-radius: var(--radius-sm); }
  .article-row__title { font-size: var(--text-lg); font-weight: 700; color: var(--color-text); margin-bottom: .5rem; letter-spacing: -.01em; transition: color .2s; }
  .article-row:hover .article-row__title { color: var(--color-purple); }
  .article-row__summary { font-size: var(--text-sm); color: var(--color-text-secondary); line-height: 1.7; margin-bottom: 1rem; }
  .article-row__footer { display: flex; justify-content: space-between; align-items: center; }
  .read-time { font-size: var(--text-xs); color: var(--color-muted); }
  .read-link { font-size: var(--text-xs); font-weight: 600; color: var(--color-muted); transition: color .2s; }
  .article-row:hover .read-link { color: var(--color-purple); }
  @media (max-width: 640px) { .inner { padding: 2rem 1.25rem 4rem; } }
</style>
