---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Navbar from '@/components/shared/Navbar.astro'
import { getLocalePath } from '@/i18n'
import { getArticles, getArticleBySlug } from '@/lib/api'
import type { Article } from '@portfolio/contracts'

export async function getStaticPaths() {
  const articles = await getArticles({ locale: 'es', pageSize: 50 })
  return articles.map(a => ({ params: { slug: a.slug }, props: { article: a } }))
}

interface Props { article: Article }
const { article } = Astro.props
const locale = 'es'

function md(text: string): string {
  return text
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/^> (.+)$/gm, '<blockquote>$1</blockquote>')
    .replace(/^- (.+)$/gm, '<li>$1</li>')
    .replace(/(<li>.*<\/li>\n?)+/g, m => `<ul>${m}</ul>`)
    .replace(/\n\n/g, '</p><p>')
    .replace(/^(?!<[hbupl])(.+)$/gm, (m) => m.startsWith('<') ? m : `<p>${m}</p>`)
}
---

<BaseLayout locale={locale} title={`${article.title} — nonedev`} description={article.summary}>
  <Navbar locale={locale} />
  <main class="article-page">
    <div class="inner">
      <a href={getLocalePath(locale, '/articulos')} class="back-link">← Artículos</a>

      <header class="article-header">
        <div class="article-header__meta">
          <time datetime={article.publishedAt!}>
            {new Date(article.publishedAt!).toLocaleDateString('es-ES', { day: '2-digit', month: 'long', year: 'numeric' })}
          </time>
          <span class="dot">·</span>
          <span>{article.readingTimeMin} min de lectura</span>
        </div>
        <h1 class="article-header__title">{article.title}</h1>
        <p class="article-header__summary">{article.summary}</p>
        <div class="article-header__tags">
          {article.tags.map(tag => <span class="pill">{tag}</span>)}
        </div>
      </header>

      <div class="article-body" set:html={md(article.content)} />

      <footer class="article-footer">
        <a href={getLocalePath(locale, '/articulos')} class="back-link">← Volver a artículos</a>
      </footer>
    </div>
  </main>
</BaseLayout>

<style>
  .article-page { min-height: 100svh; padding-top: var(--nav-h); }
  .inner { max-width: 680px; margin: 0 auto; padding: 4rem 2rem 6rem; }
  .back-link { display: inline-flex; align-items: center; gap: .4rem; font-size: var(--text-sm); color: var(--color-muted); margin-bottom: 2.5rem; transition: color .2s; }
  .back-link:hover { color: var(--color-text); }
  .article-header { margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid var(--color-border); }
  .article-header__meta { display: flex; align-items: center; gap: .5rem; font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-muted); margin-bottom: 1.25rem; }
  .dot { opacity: .4; }
  .article-header__title { font-size: clamp(1.75rem, 3.5vw, 2.75rem); font-weight: 800; letter-spacing: -.03em; line-height: 1.15; margin-bottom: 1rem; }
  .article-header__summary { font-size: var(--text-base); color: var(--color-text-secondary); line-height: 1.75; margin-bottom: 1.5rem; }
  .article-header__tags { display: flex; flex-wrap: wrap; gap: .4rem; }
  .pill { font-family: var(--font-mono); font-size: 10px; color: var(--color-muted); background: rgba(255,255,255,.04); border: 1px solid var(--color-border); padding: .2rem .55rem; border-radius: var(--radius-sm); }
  .article-body { font-size: var(--text-base); color: var(--color-text-secondary); line-height: 1.85; }
  .article-body :global(h2) { font-size: 1.35rem; font-weight: 700; color: var(--color-text); margin: 2.5rem 0 1rem; letter-spacing: -.02em; }
  .article-body :global(h3) { font-size: 1.1rem; font-weight: 600; color: var(--color-text); margin: 2rem 0 .75rem; }
  .article-body :global(p) { margin-bottom: 1.25rem; }
  .article-body :global(strong) { color: var(--color-text); font-weight: 600; }
  .article-body :global(blockquote) { border-left: 3px solid var(--color-purple); padding-left: 1.25rem; color: var(--color-text-secondary); font-style: italic; margin: 1.5rem 0; }
  .article-body :global(ul) { padding-left: 1.5rem; margin-bottom: 1.25rem; }
  .article-body :global(li) { margin-bottom: .5rem; list-style: disc; }
  .article-footer { margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--color-border); }
  @media (max-width: 640px) { .inner { padding: 2rem 1.25rem 4rem; } }
</style>
