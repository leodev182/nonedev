{
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "node_modules/.bin/esbuild api/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=api/index.js --external:pino-pretty --external:pg-native && rm api/index.ts",
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }]
}
