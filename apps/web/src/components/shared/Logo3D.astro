---
// Logo nonedev con efecto 3D CSS — más fiable que Three.js en 44px
---

<a href="/" class="logo3d" aria-label="nonedev — inicio">
  <span class="logo3d__glow" aria-hidden="true"></span>
  <img
    src="/logo.svg"
    alt="nonedev logo"
    class="logo3d__img"
    width="36"
    height="36"
    draggable="false"
  />
</a>

<style>
  .logo3d {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    perspective: 200px;
  }

  .logo3d__glow {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(155,93,229,0.18) 0%, transparent 70%);
    transition: opacity 0.3s;
    opacity: 0;
  }

  .logo3d:hover .logo3d__glow {
    opacity: 1;
  }

  .logo3d__img {
    position: relative;
    z-index: 1;
    width: 36px;
    height: 36px;
    object-fit: contain;
    /* Glow verde sutil en reposo */
    filter: drop-shadow(0 0 5px rgba(0, 232, 122, 0.3));
    /* Animación de float */
    animation: logo-float 4s ease-in-out infinite;
    transform-style: preserve-3d;
    transition: filter 0.3s;
    will-change: transform, filter;
  }

  .logo3d:hover .logo3d__img {
    animation: logo-tilt 0.6s ease-out forwards;
    filter: drop-shadow(0 0 10px rgba(155, 93, 229, 0.6))
            drop-shadow(0 0 20px rgba(0, 232, 122, 0.2));
  }

  @keyframes logo-float {
    0%, 100% {
      transform: translateY(0px) rotateY(0deg);
      filter: drop-shadow(0 0 5px rgba(0, 232, 122, 0.3));
    }
    25% {
      transform: translateY(-2px) rotateY(8deg);
      filter: drop-shadow(0 0 8px rgba(0, 232, 122, 0.4));
    }
    75% {
      transform: translateY(1px) rotateY(-6deg);
      filter: drop-shadow(0 0 5px rgba(155, 93, 229, 0.35));
    }
  }

  @keyframes logo-tilt {
    0%   { transform: rotateY(0deg) scale(1); }
    30%  { transform: rotateY(25deg) scale(1.08); }
    60%  { transform: rotateY(-15deg) scale(1.05); }
    100% { transform: rotateY(0deg) scale(1); }
  }
</style>
