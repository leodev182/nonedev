---
import type { Locale } from '@/i18n'
import type { Project } from '@portfolio/contracts'
import { useTranslations, getLocalePath } from '@/i18n'

interface Props {
  locale: Locale
  projects: Project[]
}

const { locale, projects } = Astro.props
const t = useTranslations(locale)
---

<div class="section-divider"><hr /></div>

<section id="proyectos" class="section">
  <div class="section__header">
    <p class="section__tag">{t('proyectos', 'etiqueta')}</p>
    <h2 class="section__title">{t('proyectos', 'titulo')}</h2>
    <p class="section__subtitle">{t('proyectos', 'subtitulo')}</p>
  </div>

  <div class="projects-grid">
    {projects.map((project) => (
      <a
        href={getLocalePath(locale, `/proyectos/${project.slug}`)}
        class="project-card"
      >
        <!-- Thumbnail -->
        <div class="project-card__thumb">
          {project.coverUrl
            ? <img src={project.coverUrl} alt={project.title} loading="lazy" />
            : <div class="project-card__thumb-placeholder">
                <span class="project-card__thumb-letter">{project.title.charAt(0)}</span>
              </div>
          }
          <div class="project-card__platform">
            {project.platforms.map(p => (
              <span class="platform-tag">{p.toUpperCase()}</span>
            ))}
          </div>
        </div>

        <!-- Cuerpo -->
        <div class="project-card__body">
          <h3 class="project-card__title">{project.title}</h3>
          <p class="project-card__summary">{project.summary}</p>
          <div class="project-card__footer">
            <div class="project-card__tags">
              {project.stack.slice(0, 3).map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <span class="project-card__link">
              {t('proyectos', 'ver')}
              <span class="project-card__link-arrow">→</span>
            </span>
          </div>
        </div>
      </a>
    ))}
  </div>

  <a href={getLocalePath(locale, '/proyectos')} class="see-all">
    {t('proyectos', 'verTodos')}
    <span class="see-all__arrow">→</span>
  </a>
</section>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color 0.25s var(--ease), transform 0.25s var(--ease), box-shadow 0.25s var(--ease);
    position: relative;
  }

  .project-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(135deg, var(--color-purple-dim) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.3s var(--ease);
    pointer-events: none;
    z-index: 0;
  }

  .project-card:hover {
    border-color: rgba(139, 92, 246, 0.4);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35), 0 0 0 1px rgba(139, 92, 246, 0.08);
  }

  .project-card:hover::before { opacity: 1; }

  /* Thumbnail */
  .project-card__thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: linear-gradient(
      135deg,
      rgba(139, 92, 246, 0.12) 0%,
      rgba(0, 232, 122, 0.04) 50%,
      rgba(9, 9, 14, 0.7) 100%
    );
    border-bottom: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
  }

  .project-card__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s var(--ease);
  }

  .project-card:hover .project-card__thumb img { transform: scale(1.04); }

  .project-card__thumb-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(139,92,246,0.12) 0%, rgba(0,232,122,0.04) 50%, rgba(9,9,14,0.7) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .project-card__thumb-letter {
    font-size: 4rem;
    font-weight: 800;
    color: rgba(255,255,255,0.06);
    user-select: none;
  }

  .project-card__platform {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .platform-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--color-green);
    background: rgba(0, 232, 122, 0.1);
    border: 1px solid rgba(0, 232, 122, 0.2);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
  }

  /* Cuerpo */
  .project-card__body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 1;
  }

  .project-card__title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.625rem;
    letter-spacing: -0.01em;
  }

  .project-card__summary {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.65;
    flex: 1;
    margin-bottom: 1.25rem;
  }

  .project-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .project-card__tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }

  .tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 0.2rem 0.55rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-muted);
  }

  .project-card__link {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-secondary);
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    white-space: nowrap;
    transition: color 0.2s var(--ease);
    flex-shrink: 0;
  }

  .project-card:hover .project-card__link { color: var(--color-purple); }

  .project-card__link-arrow { display: inline-block; transition: transform 0.2s var(--ease); }
  .project-card:hover .project-card__link-arrow { transform: translateX(3px); }
</style>
