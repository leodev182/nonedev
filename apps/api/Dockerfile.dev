FROM node:22-alpine

# Habilitar pnpm via corepack
RUN corepack enable && corepack prepare pnpm@10 --activate

WORKDIR /app

# Copiar manifiestos del workspace primero (cache de layers)
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/contracts/package.json ./packages/contracts/
COPY packages/logger/package.json ./packages/logger/
COPY apps/api/package.json ./apps/api/

# Instalar todas las dependencias del workspace
RUN pnpm install --frozen-lockfile

# El código fuente viene por volume mount, no se copia aquí
# Esto permite hot reload sin reconstruir la imagen

CMD ["pnpm", "--filter", "@portfolio/api", "dev"]
